---
import { ArrowRight, MessageCircle, CheckCircle } from "@lucide/astro";
---

<section class="hero" id="hero-section">
  <div class="hero__container">
    <div class="hero__badges">
      <span class="hero__badge">Google Ads para pymes y servicios profesionales en Chile</span>
    </div>

    <div class="hero__split">
      <!-- Left: title -->
      <div class="hero__left">
        <h1 class="hero__title">
          <span class="hero-line hero-line--1"
            ><span>Tu negocio o servicio profesional en el</span></span
          >
          <span class="hero-line hero-line--2"
            ><span>primer lugar de Google.</span></span
          >
          <span class="hero-line hero-line--3"
            ><span class="hero__accent">Nosotros hacemos que</span></span
          >
          <span class="hero-line hero-line--4"
            ><span class="hero__accent">el teléfono suene.</span></span
          >
        </h1>
      </div>

      <!-- Right: sub + trust + CTAs -->
      <div class="hero__right">
        <p class="hero__sub">
          Gestionamos y optimizamos tus campañas cada semana para que recibas
          consultas de clientes reales. Sin contrato. <strong
            >Desde $59.000/mes + IVA.</strong
          >
        </p>

        <div class="hero__trust-row">
          <span class="hero__trust-item">
            <CheckCircle size={14} />
            Optimización semanal real
          </span>
          <span class="hero__trust-item">
            <CheckCircle size={14} />
            Tu cuenta siempre es tuya
          </span>
          <span class="hero__trust-item">
            <CheckCircle size={14} />
            Sin contrato de permanencia
          </span>
        </div>

        <div class="hero__cta-group">
          <a
            href="https://wa.me/56987435207?text=Hola%2C%20tengo%20un%20negocio%20y%20quiero%20saber%20c%C3%B3mo%20Google%20Ads%20me%20puede%20traer%20m%C3%A1s%20clientes"
            target="_blank"
            rel="noopener"
            class="btn-wa"
          >
            <MessageCircle size={18} />
            Quiero más clientes
          </a>
          <a href="#planes" class="btn-secondary hero__btn-sec">
            Ver planes y precios
            <ArrowRight size={16} />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  window.addEventListener(
    "load",
    () => {
      setTimeout(() => {
        document.getElementById("hero-section")?.classList.add("hero--ready");
      }, 100);
    },
    { once: true },
  );
</script>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    align-items: center;
    background: var(--white);
    padding: clamp(5.5rem, 10vh, 7rem) 0 clamp(2.5rem, 5vh, 4rem);
  }
  .hero__container {
    width: 100%;
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 var(--section-px);
    display: flex;
    flex-direction: column;
    gap: clamp(1.5rem, 3vh, 2.5rem);
  }

  /* Badge */
  .hero__badges {
    opacity: 0;
  }
  .hero--ready .hero__badges {
    animation: heroFadeIn 0.5s ease 0.05s both;
  }
  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.875rem;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: 99px;
    border: 1px solid rgba(22, 163, 74, 0.15);
  }

  /* Split layout */
  .hero__split {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  @media (min-width: 900px) {
    .hero__split {
      flex-direction: row;
      align-items: flex-start;
      gap: clamp(3rem, 5vw, 5rem);
    }
    .hero__left {
      flex: 1.2;
      min-width: 0;
    }
    .hero__right {
      flex: 0.8;
      padding-top: 0.5rem;
    }
  }

  /* Title */
  .hero__title {
    font-size: clamp(2.25rem, 5.5vw, 4.25rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.04em;
    color: var(--black);
  }
  .hero-line {
    display: block;
    overflow: hidden;
  }
  .hero-line > span {
    display: block;
    transform: translateY(110%);
  }
  .hero--ready .hero-line > span {
    animation: heroSlideUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .hero--ready .hero-line--1 > span {
    animation-delay: 0.1s;
  }
  .hero--ready .hero-line--2 > span {
    animation-delay: 0.2s;
  }
  .hero--ready .hero-line--3 > span {
    animation-delay: 0.35s;
  }
  .hero--ready .hero-line--4 > span {
    animation-delay: 0.45s;
  }
  @keyframes heroSlideUp {
    from {
      transform: translateY(110%);
    }
    to {
      transform: translateY(0);
    }
  }

  .hero__accent {
    color: var(--accent);
  }

  /* Right column content */
  .hero__right {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    opacity: 0;
  }
  .hero--ready .hero__right {
    animation: heroFadeIn 0.6s ease both 0.55s;
  }
  @keyframes heroFadeIn {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (min-width: 900px) {
    .hero__right {
      border-left: 1px solid var(--gray-200);
      padding-left: clamp(2rem, 3.5vw, 3.5rem);
    }
  }
  @media (max-width: 899px) {
    .hero__right {
      padding-top: 1.25rem;
      border-top: 1px solid var(--gray-200);
    }
  }

  .hero__sub {
    font-size: clamp(0.9375rem, 1.1vw, 1.0625rem);
    line-height: 1.65;
    color: var(--gray-600);
  }
  .hero__sub strong {
    color: var(--black);
    font-weight: 600;
  }

  /* Trust row */
  .hero__trust-row {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .hero__trust-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--gray-500);
  }
  .hero__trust-item :global(svg) {
    color: var(--accent);
    flex-shrink: 0;
  }

  /* CTA group */
  .hero__cta-group {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 0.5rem;
  }
  @media (min-width: 500px) and (max-width: 899px) {
    .hero__cta-group {
      flex-direction: row;
      gap: 1rem;
    }
  }
  .hero__btn-sec {
    text-align: center;
    justify-content: center;
  }
  @media (max-width: 499px) {
    .hero__cta-group .btn-wa,
    .hero__cta-group .btn-secondary {
      width: 100%;
      justify-content: center;
    }
  }

  /* Mobile tweaks */
  @media (max-width: 899px) {
    .hero {
      min-height: auto;
      align-items: flex-start;
      padding-top: 5.5rem;
      padding-bottom: 1.5rem;
    }
  }
</style>
