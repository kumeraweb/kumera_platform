---
interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  noIndex?: boolean;
}

import "../styles/global.css";

const SITE_URL = "https://sitiora.kumeraweb.com";
const FORM_CONVERSION_SEND_TO =
  import.meta.env.PUBLIC_GOOGLE_ADS_FORM_SEND_TO || "";

const {
  title = "Sitiora para Pymes y Servicios - Kumera",
  description = "Creamos landing pages, webs corporativas y proyectos web de mayor escala para empresas en Chile. Servicio orientado a conversion comercial y crecimiento.",
  canonical = SITE_URL,
  noIndex = false,
} = Astro.props;
---

<!doctype html>
<html lang="es-CL">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content={noIndex ? "noindex, nofollow" : "index, follow"} />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Kumera" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Sitiora Kumera" />
    <meta property="og:locale" content="es_CL" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <meta name="theme-color" content="#f5f5f0" />
    <meta name="color-scheme" content="light" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <script
      async
      src="https://www.googletagmanager.com/gtag/js?id=AW-17993579804"></script>
    <script
      is:inline
      set:html={`window.__SITIORA_FORM_SEND_TO__ = ${JSON.stringify(FORM_CONVERSION_SEND_TO)};`}
    />
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      window.gtag =
        window.gtag ||
        function () {
          window.dataLayer.push(arguments);
        };
      window.gtag_report_conversion = function (url) {
        var callback = function () {
          if (typeof url !== "undefined") {
            window.location = url;
          }
        };
        window.gtag("event", "conversion", {
          send_to: "AW-17993579804/dG3-CL3xjoMcEJz6gIRD",
          value: 1.0,
          currency: "CLP",
          event_callback: callback,
        });
        return false;
      };
      window.gtag_report_form_conversion = function (url) {
        var callback = function () {
          if (typeof url !== "undefined") {
            window.location = url;
          }
        };
        if (!window.__SITIORA_FORM_SEND_TO__ || typeof window.gtag !== "function") {
          callback();
          return false;
        }
        window.gtag("event", "conversion", {
          send_to: window.__SITIORA_FORM_SEND_TO__,
          value: 1.0,
          currency: "CLP",
          event_callback: callback,
        });
        window.setTimeout(callback, 1200);
        return false;
      };
      window.gtag("js", new Date());
      window.gtag("config", "AW-17993579804");
    </script>

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        name: "Sitiora Kumera",
        description:
          "Servicio de desarrollo web para pymes y servicios: landing pages, sitios corporativos y proyectos a medida.",
        url: SITE_URL,
        email: "contacto@kumeraweb.com",
        telephone: "+56954387442",
        address: {
          "@type": "PostalAddress",
          addressCountry: "CL",
          addressLocality: "Santiago",
        },
        areaServed: {
          "@type": "Country",
          name: "Chile",
        },
        priceRange: "$$",
        currenciesAccepted: "CLP",
      })}
    />
  </head>
  <body>
    <slot />
  </body>
</html>
