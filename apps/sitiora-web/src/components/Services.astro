---
const services = [
    {
        idx: "01",
        title: "Landing Start / Growth",
        description:
            "Nuestra línea principal para volumen. Landings comerciales rápidas, alcance claro y pensadas para emprendedores y pymes de servicios.",
        tags: [
            "Desde $79.000",
            "Entrega rápida",
            "CTA · formulario · WhatsApp",
        ],
    },
    {
        idx: "02",
        title: "Web Pro / Multipágina",
        description:
            "Cuando el negocio necesita más profundidad comercial: más páginas, mejor estructura y narrativa para vender servicios de mayor valor.",
        tags: ["Hasta 5 páginas", "SEO base", "Escalable"],
        highlighted: true,
    },
    {
        idx: "03",
        title: "E-commerce",
        description:
            "No es nuestro producto principal. Se trabaja solo en proyectos donde exista presupuesto y operación para sostener e-commerce en serio.",
        tags: ["Ticket alto", "Evaluación previa", "Implementación a medida"],
    },
    {
        idx: "04",
        title: "Enterprise / A Medida",
        description:
            "Portales de clientes, intranets, sistemas web complejos y arquitecturas personalizadas bajo requerimientos específicos de negocio.",
        tags: ["Lógica de negocio", "Bases de datos", "Integraciones API"],
    },
];
---

<section id="servicios" class="py-28 md:py-44 relative">
    <div class="max-w-[1400px] mx-auto px-6 md:px-10">
        <div class="mb-16 md:mb-24 reveal">
            <p class="section-label mb-8">Servicios</p>
            <h2
                class="font-display text-[clamp(2.25rem,5.5vw,5rem)] leading-[1.0] tracking-[-0.025em] text-fg max-w-3xl"
            >
                Soluciones web orientadas a resultados de negocio.
            </h2>
        </div>

        <div>
            {
                services.map((service, i) => (
                    <div
                        class:list={[
                            "grid md:grid-cols-[80px_1fr_2fr] gap-6 md:gap-10 py-10 md:py-12 border-t border-border group cursor-default reveal",
                            `reveal-delay-${i + 1}`,
                        ]}
                    >
                        {/* Index */}
                        <div class="flex items-start md:items-start pt-1">
                            <span
                                class="text-accent-green"
                                style="font-family: var(--font-mono); font-size: 0.625rem; letter-spacing: 0.1em;"
                                aria-hidden="true"
                            >
                                {service.idx}
                            </span>
                        </div>

                        {/* Title */}
                        <div class="flex flex-col justify-between">
                            <div class="flex items-center gap-3 flex-wrap">
                                <span class="font-display text-2xl md:text-3xl text-fg leading-tight group-hover:translate-x-1 transition-transform duration-500">
                                    {service.title}
                                </span>
                                {service.highlighted && (
                                    <span
                                        class="w-1.5 h-1.5 rounded-full bg-accent-green inline-block"
                                        title="Popular"
                                        aria-label="Popular"
                                    />
                                )}
                            </div>
                        </div>

                        {/* Content */}
                        <div>
                            <p
                                class="text-muted text-sm md:text-base leading-relaxed mb-5"
                                style="font-weight: 300;"
                            >
                                {service.description}
                            </p>
                            <div class="flex flex-wrap gap-x-4 gap-y-1">
                                {service.tags.map((tag: string, ti: number) => (
                                    <span class="section-label">{tag}</span>
                                ))}
                            </div>
                        </div>
                    </div>
                ))
            }
            <div class="border-t border-border"></div>
        </div>
    </div>
</section>
