---
const steps = [
    {
        num: "01",
        title: "Discovery",
        description:
            "Levantamos tu objetivo comercial, entendemos tu oferta de valor y definimos a tu público objetivo.",
    },
    {
        num: "02",
        title: "Propuesta",
        description:
            "Estructuramos alcance, entregables, tiempos fijos y presupuesto claro. Sin sorpresas.",
    },
    {
        num: "03",
        title: "Construcción",
        description:
            "Desarrollo iterativo con visibilidad de avances. Nos alineamos contigo hasta el lanzamiento.",
    },
    {
        num: "04",
        title: "Activación",
        description:
            "Firma contractual formal y pagos transparentes vía plataforma Kumera Billing.",
    },
];
---

<section
    id="proceso"
    class="py-28 md:py-44 bg-fg text-bg relative overflow-hidden"
>
    {/* Subtle grain texture overlay */}
    <div
        class="absolute inset-0 opacity-[0.025] pointer-events-none"
        aria-hidden="true"
        style="background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E&quot;); background-size: 200px;"
    >
    </div>

    <div class="max-w-[1400px] mx-auto px-6 md:px-10 relative z-10">
        <div class="mb-16 md:mb-24 max-w-3xl reveal">
            <p class="section-label text-accent-green/70 mb-8">Proceso</p>
            <h2
                class="font-display text-[clamp(2.25rem,5.5vw,5rem)] leading-[1.0] tracking-[-0.025em] text-bg"
            >
                Metodología transparente, de principio a fin.
            </h2>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-0">
            {
                steps.map((step, i) => (
                    <div
                        class:list={[
                            "py-10 md:py-0 md:pr-12 group relative reveal",
                            i > 0
                                ? "border-t md:border-t-0 md:border-l border-bg/10 md:pl-12"
                                : "",
                            `reveal-delay-${i + 1}`,
                        ]}
                    >
                        <span
                            class="font-display leading-none text-bg/8 group-hover:text-accent-green/20 transition-colors duration-700 mb-8 block select-none"
                            style="font-size: clamp(4rem, 8vw, 7rem);"
                            aria-hidden="true"
                        >
                            {step.num}
                        </span>
                        <h3 class="text-base font-semibold text-bg mb-3 tracking-[-0.01em]">
                            {step.title}
                        </h3>
                        <p
                            class="text-bg/50 text-sm leading-relaxed"
                            style="font-weight: 300;"
                        >
                            {step.description}
                        </p>
                    </div>
                ))
            }
        </div>
    </div>
</section>

{/* Social Proof Strip */}
<section class="py-14 md:py-18 border-b border-border">
    <div class="max-w-[1400px] mx-auto px-6 md:px-10">
        <div
            class="flex flex-col md:flex-row items-center justify-between gap-8 reveal"
        >
            <div class="flex items-baseline gap-4">
                <span
                    class="font-display text-[clamp(2.5rem,5vw,4rem)] text-fg leading-none"
                    >+20</span
                >
                <span class="section-label">clientes<br />satisfechos</span>
            </div>

            <div class="hidden md:block w-px h-10 bg-border"></div>

            <p
                class="text-muted text-sm max-w-sm leading-relaxed text-center md:text-left"
                style="font-weight: 300;"
            >
                Empresas y profesionales en Chile que convirtieron su presencia
                digital en un canal real de captación comercial.
            </p>

            <div class="hidden md:block w-px h-10 bg-border"></div>

            <div class="flex items-center gap-1">
                {
                    [1, 2, 3, 4, 5].map(() => (
                        <svg
                            width="14"
                            height="14"
                            viewBox="0 0 14 14"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                            aria-hidden="true"
                        >
                            <path
                                d="M7 1L8.5 5.5H13L9.5 8L11 12.5L7 10L3 12.5L4.5 8L1 5.5H5.5L7 1Z"
                                stroke="currentColor"
                                stroke-width="0.8"
                                fill="none"
                                class="text-fg/60"
                            />
                        </svg>
                    ))
                }
            </div>
        </div>
    </div>
</section>
