---
const whatsappMessage = encodeURIComponent(
    "Hola, quiero cotizar un sitio web para mi negocio.",
);
const whatsappUrl = `https://wa.me/56994186218?text=${whatsappMessage}`;
---

<section
    class="relative pt-36 pb-24 md:pt-52 md:pb-36 lg:pt-60 lg:pb-44 overflow-hidden"
>
    {/* Número de referencia editorial */}
    <span
        class="absolute top-24 right-6 md:right-10 section-label text-border-strong select-none hidden md:block"
        aria-hidden="true">/001</span
    >

    <div class="max-w-[1400px] mx-auto px-6 md:px-10">
        {/* Eyebrow label */}
        <p class="section-label mb-8 md:mb-10 reveal">
            Agencia de Diseño Web — Chile
        </p>

        <div class="mb-6 md:mb-8 reveal reveal-delay-1">
            <span
                class="inline-flex items-center rounded-full border border-border bg-bg px-4 py-2 section-label text-fg/65"
                title="Sitiora es una empresa operada por Kumera Servicios Digitales SpA."
            >
                Operada por Kumera Servicios Digitales SpA
            </span>
        </div>

        {/* Headline monumental */}
        <h1
            class="font-display text-[clamp(3.25rem,9.5vw,10.5rem)] leading-[0.9] tracking-[-0.035em] text-fg mb-10 md:mb-14 max-w-[1150px] reveal reveal-delay-1"
        >
            Diseñamos sitios web que generan <em class="italic"
                >clientes reales</em
            >
        </h1>

        <div
            class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 md:gap-16"
        >
            <p
                class="text-base md:text-lg text-muted max-w-lg leading-relaxed reveal reveal-delay-2"
                style="font-weight: 300;"
            >
                Agencia enfocada en conversión comercial. Planes desde $79.000
                para emprendedores, hasta soluciones enterprise para empresas
                que necesitan más.
            </p>

            <div
                class="flex flex-col sm:flex-row items-start sm:items-center gap-3 reveal reveal-delay-2"
            >
                <a
                    href="#contacto"
                    class="inline-flex items-center justify-center border border-fg bg-fg text-bg hover:bg-transparent hover:text-fg transition-all duration-300 px-8 py-3.5 rounded-sm"
                    style="font-size: 0.875rem; letter-spacing: 0.01em;"
                >
                    Solicitar Propuesta
                </a>
                <a
                    href={whatsappUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center border border-border text-fg hover:border-fg transition-all duration-300 px-8 py-3.5 rounded-sm"
                    style="font-size: 0.875rem; letter-spacing: 0.01em;"
                >
                    WhatsApp Directo
                </a>
            </div>
        </div>

        {/* Línea separadora */}
        <div class="h-px bg-border mt-20 md:mt-28 line-appear"></div>

        {/* Stats row */}
        <div class="grid grid-cols-2 md:grid-cols-4 mt-0">
            {
                [
                    { num: "7–14", label: "días una landing" },
                    { num: "100%", label: "foco en conversión" },
                    { num: "CRO", label: "listo para Google Ads" },
                    { num: "+20", label: "clientes en Chile" },
                ].map((stat, i) => (
                    <div
                        class:list={[
                            "py-8 md:py-10 reveal",
                            `reveal-delay-${i + 1}`,
                            i > 0 ? "border-l border-border pl-6 md:pl-10" : "",
                            i > 0 ? "" : "pr-6 md:pr-10",
                        ]}
                    >
                        <p class="font-display text-[clamp(2.25rem,5vw,3.75rem)] text-fg leading-none mb-2">
                            {stat.num}
                        </p>
                        <p class="section-label">{stat.label}</p>
                    </div>
                ))
            }
        </div>

        {/* Scroll hint */}
        <div class="mt-4 flex items-center gap-3 reveal reveal-delay-4">
            <div class="scroll-hint">
                <div class="w-px h-8 bg-muted/30"></div>
                <div class="w-1 h-1 rounded-full bg-muted/50"></div>
            </div>
            <span class="section-label">scroll</span>
        </div>
    </div>
</section>
