---
const whatsappMessage = encodeURIComponent(
    "Hola, quiero cotizar un sitio web para mi negocio.",
);
const whatsappUrl = `https://wa.me/56994186218?text=${whatsappMessage}`;
---

<section class="pt-32 pb-20 md:pt-44 md:pb-32 lg:pt-52 lg:pb-40">
    <div class="max-w-[1400px] mx-auto px-6 md:px-10">
        <h1
            class="font-display text-[clamp(2.8rem,8vw,8rem)] leading-[0.95] tracking-[-0.03em] text-fg mb-8 md:mb-12 max-w-[1200px] reveal"
        >
            Diseñamos sitios web que generan <em class="italic"
                >clientes reales</em
            >
        </h1>

        <div
            class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 md:gap-16"
        >
            <p
                class="text-lg md:text-xl text-muted max-w-xl leading-relaxed reveal reveal-delay-1"
            >
                Agencia de diseño web en Chile enfocada en conversión comercial.
                Planes accesibles para emprendedores desde $79.000 y escalamiento
                a soluciones premium para empresas que necesitan más alcance.
            </p>

            <div
                class="flex flex-col sm:flex-row items-start sm:items-center gap-4 reveal reveal-delay-2"
            >
                <a
                    href="#contacto"
                    class="inline-flex items-center justify-center rounded-full px-8 py-4 text-base font-medium bg-fg text-bg hover:bg-fg/85 transition-colors duration-300"
                >
                    Solicitar Propuesta
                </a>
                <a
                    href={whatsappUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center rounded-full px-8 py-4 text-base font-medium border border-border text-fg hover:bg-fg hover:text-bg transition-all duration-300"
                >
                    WhatsApp Directo
                </a>
            </div>
        </div>

        <div class="h-px bg-border mt-16 md:mt-24 line-appear"></div>

        <div
            class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12 mt-12 md:mt-16"
        >
            <div class="reveal reveal-delay-1">
                <p class="font-display text-4xl md:text-5xl text-fg mb-1">
                    7–14
                </p>
                <p class="text-sm text-muted">días una landing</p>
            </div>
            <div class="reveal reveal-delay-2">
                <p class="font-display text-4xl md:text-5xl text-fg mb-1">
                    100%
                </p>
                <p class="text-sm text-muted">foco en conversión</p>
            </div>
            <div class="reveal reveal-delay-3">
                <p class="font-display text-4xl md:text-5xl text-fg mb-1">
                    CRO
                </p>
                <p class="text-sm text-muted">optimizado para ads</p>
            </div>
            <div class="reveal reveal-delay-4">
                <p class="font-display text-4xl md:text-5xl text-fg mb-1">
                    Chile
                </p>
                <p class="text-sm text-muted">foco regional</p>
            </div>
        </div>
    </div>
</section>
