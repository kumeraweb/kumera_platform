---
const plans = [
    {
        name: "Start",
        sub: "Emprendedores · landing esencial",
        price: "desde $79.000",
    },
    {
        name: "Growth",
        sub: "Volumen comercial · landing optimizada",
        price: "desde $149.000",
    },
    {
        name: "Pro",
        sub: "Multipágina liviana · ticket medio",
        price: "desde $249.000",
    },
    {
        name: "Custom",
        sub: "Alcance avanzado a medida",
        price: "desde $490.000",
        underline: true,
    },
    {
        name: "E-commerce",
        sub: "Solo bajo evaluación técnica",
        price: "desde $1.290.000",
    },
];

const faqs = [
    {
        q: "¿Incluyen dominio y hosting?",
        a: "Normalmente sugerimos que el cliente adquiera su propio dominio y hosting para mantener propiedad total. Podemos configurar todo y en planes corporativos incluimos el alojamiento del primer año si lo necesitas.",
    },
    {
        q: "¿En cuánto tiempo entregan el sitio?",
        a: "Plan Start entre 3 y 5 días hábiles. Plan Growth entre 5 y 7 días hábiles. Plan Pro y superiores según alcance. Los tiempos finales dependen de la velocidad de feedback y entrega de contenidos.",
    },
    {
        q: "¿Mi sitio estará listo para Google Ads?",
        a: "Sí. Ese es nuestro diferenciador. Tu sitio se entrega con SEO técnico base, velocidad de carga óptima y estructura persuasiva lista para que inyectes tráfico pagado y comience a captar leads desde el día 1.",
    },
    {
        q: "¿Por qué tienen un plan desde $79.000?",
        a: "Porque usamos procesos asistidos por IA para acelerar producción en proyectos acotados. El plan de entrada tiene alcance controlado y está pensado para emprendedores y profesionales que necesitan salir rápido al mercado.",
    },
    {
        q: "¿Cómo es la forma de pago?",
        a: "Gestionamos cobros vía plataforma Kumera Billing. Operamos por transferencia bancaria y dejamos condiciones formales por contrato. Habitualmente trabajamos con 50% al inicio y 50% contra entrega.",
    },
    {
        q: "¿Qué pasa si necesito cambios después?",
        a: "Incluimos un período de ajustes post-lanzamiento. Si tu proyecto requiere mantención continua o iteraciones futuras, podemos acordar un plan de soporte mensual adaptado.",
    },
];
---

<section id="precios" class="py-28 md:py-44">
    <div class="max-w-[1400px] mx-auto px-6 md:px-10">
        <div class="grid lg:grid-cols-2 gap-16 lg:gap-28">
            {/* Pricing Column */}
            <div>
                <p class="section-label mb-8 reveal">Inversión</p>
                <h2
                    class="font-display text-[clamp(2.25rem,5.5vw,5rem)] leading-[1.0] tracking-[-0.025em] text-fg mb-14 md:mb-18 reveal reveal-delay-1"
                >
                    Escalera de entrada y crecimiento.
                </h2>

                <div class="reveal reveal-delay-2">
                    {
                        plans.map((plan) => (
                            <div class="flex items-baseline justify-between py-5 border-t border-border group">
                                <div>
                                    <p
                                        class:list={[
                                            "text-base font-medium text-fg tracking-[-0.01em]",
                                            plan.underline
                                                ? "border-b border-fg/30 pb-px inline-block"
                                                : "",
                                        ]}
                                    >
                                        {plan.name}
                                    </p>
                                    <p class="section-label mt-1.5">
                                        {plan.sub}
                                    </p>
                                </div>
                                <p class="font-display text-lg md:text-xl text-fg whitespace-nowrap ml-6 group-hover:translate-x-0.5 transition-transform duration-300">
                                    {plan.price}
                                </p>
                            </div>
                        ))
                    }
                    <div class="border-t border-border pt-6">
                        <p class="section-label">
                            Valores en CLP + IVA · Pago único por proyecto ·
                            Extras cotizados aparte
                        </p>
                    </div>
                </div>
            </div>

            {/* FAQ Column */}
            <div>
                <p class="section-label mb-8 reveal">Preguntas Frecuentes</p>
                <h2
                    class="font-display text-[clamp(2.25rem,5.5vw,5rem)] leading-[1.0] tracking-[-0.025em] text-fg mb-14 md:mb-18 reveal reveal-delay-1"
                >
                    Resolvemos tus dudas.
                </h2>

                <div class="reveal reveal-delay-2">
                    {
                        faqs.map((faq) => (
                            <details class="group border-t border-border [&_summary::-webkit-details-marker]:hidden">
                                <summary class="flex cursor-pointer items-start justify-between py-5 text-fg font-medium text-sm md:text-base select-none gap-4 tracking-[-0.01em]">
                                    <span>{faq.q}</span>
                                    <span
                                        class="shrink-0 text-accent-green transition-transform duration-300 group-open:rotate-45 text-lg leading-none mt-0.5"
                                        aria-hidden="true"
                                    >
                                        +
                                    </span>
                                </summary>
                                <div
                                    class="pb-5 text-muted text-sm leading-relaxed pr-10"
                                    style="font-weight: 300;"
                                >
                                    {faq.a}
                                </div>
                            </details>
                        ))
                    }
                    <div class="border-t border-border"></div>
                </div>
            </div>
        </div>
    </div>
</section>
