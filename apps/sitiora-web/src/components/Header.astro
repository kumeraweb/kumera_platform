---
const whatsappMessage = encodeURIComponent(
    "Hola, quiero cotizar un sitio web para mi negocio.",
);
const whatsappUrl = `https://wa.me/56994186218?text=${whatsappMessage}`;
---

<header
    class="fixed top-0 w-full z-50 transition-all duration-500"
    id="site-header"
>
    <div
        class="max-w-[1400px] mx-auto px-6 md:px-10 h-14 flex items-center justify-between border-b border-border/70"
        id="header-inner"
    >
        <a
            href="/"
            class="text-sm font-semibold tracking-[-0.04em] text-fg"
            style="font-size: 1.0625rem;"
        >
            <span class="logo-flip">
                <span class="logo-flip-inner">
                    <span><span class="logo-brand">Sitiora</span></span>
                    <span class="logo-tagline">Tu sitio web, ahora</span>
                </span>
            </span>
        </a>

        <nav
            class="hidden md:flex items-center gap-8"
            style="font-size: 0.8125rem; letter-spacing: 0.01em;"
        >
            <a
                href="#servicios"
                class="text-muted hover:text-fg transition-colors duration-200 link-underline"
                >Servicios</a
            >
            <a
                href="#proceso"
                class="text-muted hover:text-fg transition-colors duration-200 link-underline"
                >Proceso</a
            >
            <a
                href="#precios"
                class="text-muted hover:text-fg transition-colors duration-200 link-underline"
                >Precios</a
            >
        </nav>

        <div class="flex items-center gap-4">
            <a
                href={whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="hidden sm:inline-flex items-center text-muted hover:text-fg transition-colors duration-200 link-underline"
                style="font-size: 0.8125rem;"
            >
                WhatsApp
            </a>
            <a
                href="#contacto"
                class="inline-flex items-center justify-center border border-fg/80 text-fg hover:bg-fg hover:text-bg transition-all duration-300 px-5 py-2 rounded-sm"
                style="font-size: 0.8125rem; letter-spacing: 0.01em;"
            >
                Contactar
            </a>
        </div>
    </div>
</header>

<script>
    const header = document.getElementById("site-header");
    const inner = document.getElementById("header-inner");

    if (header && inner) {
        let scrolled = false;

        const onScroll = () => {
            const isScrolled = window.scrollY > 40;
            if (isScrolled !== scrolled) {
                scrolled = isScrolled;
                if (scrolled) {
                    header.style.backgroundColor = "rgba(245, 245, 240, 0.97)";
                    header.style.backdropFilter = "blur(12px)";
                    header.style.webkitBackdropFilter = "blur(12px)";
                } else {
                    header.style.backgroundColor = "transparent";
                    header.style.backdropFilter = "none";
                    header.style.webkitBackdropFilter = "none";
                }
            }
        };

        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();
    }
</script>
