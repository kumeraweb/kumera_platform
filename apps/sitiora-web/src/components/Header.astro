---
const whatsappMessage = encodeURIComponent(
    "Hola, quiero cotizar un sitio web para mi negocio.",
);
const whatsappUrl = `https://wa.me/56994186218?text=${whatsappMessage}`;
---

<header
    class="fixed top-0 w-full z-50 bg-bg/95 backdrop-blur-sm border-b border-border"
>
    <div
        class="max-w-[1400px] mx-auto px-6 md:px-10 h-16 flex items-center justify-between"
    >
        <a href="/" class="text-xl font-bold tracking-tight text-fg">
            <span class="logo-flip">
                <span class="logo-flip-inner">
                    <span><span class="logo-brand">Sitiora</span></span>
                    <span class="logo-tagline">Tu sitio web, ahora</span>
                </span>
            </span>
        </a>

        <nav class="hidden md:flex items-center gap-10 text-sm text-muted">
            <a
                href="#servicios"
                class="hover:text-fg transition-colors duration-300"
                >Servicios</a
            >
            <a
                href="#proceso"
                class="hover:text-fg transition-colors duration-300">Proceso</a
            >
            <a
                href="#precios"
                class="hover:text-fg transition-colors duration-300">Precios</a
            >
        </nav>

        <div class="flex items-center gap-3">
            <a
                href={whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="hidden sm:inline-flex items-center text-sm text-muted hover:text-fg transition-colors duration-300"
            >
                WhatsApp
            </a>
            <a
                href="#contacto"
                class="inline-flex items-center justify-center rounded-full px-5 py-2 text-sm font-medium bg-fg text-bg hover:bg-fg/85 transition-colors duration-300"
            >
                Contactar
            </a>
        </div>
    </div>
</header>
