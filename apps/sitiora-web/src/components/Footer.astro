<footer class="bg-fg text-bg py-16 md:py-24">
    <div class="max-w-[1400px] mx-auto px-6 md:px-10">
        <div class="grid md:grid-cols-3 gap-12 md:gap-16 mb-16 md:mb-24">
            <div>
                <a
                    href="/"
                    class="text-2xl font-bold tracking-tight text-bg mb-4 inline-block"
                >
                    <span class="logo-flip">
                        <span class="logo-flip-inner">
                            <span><span class="logo-brand">Sitiora</span></span>
                            <span class="logo-tagline">Tu sitio web, ahora</span
                            >
                        </span>
                    </span>
                </a>
                <p class="text-bg/50 text-sm max-w-xs leading-relaxed">
                    Agencia de diseño web en Chile enfocada en conversión
                    comercial. Parte de Kumera Platform.
                </p>
            </div>

            <div>
                <p class="text-xs uppercase tracking-[0.15em] text-bg/40 mb-4">
                    Navegación
                </p>
                <ul class="space-y-2 text-sm">
                    <li>
                        <a
                            href="#servicios"
                            class="text-bg/70 hover:text-bg transition-colors duration-300"
                            >Servicios</a
                        >
                    </li>
                    <li>
                        <a
                            href="#proceso"
                            class="text-bg/70 hover:text-bg transition-colors duration-300"
                            >Proceso</a
                        >
                    </li>
                    <li>
                        <a
                            href="#precios"
                            class="text-bg/70 hover:text-bg transition-colors duration-300"
                            >Precios</a
                        >
                    </li>
                    <li>
                        <a
                            href="#contacto"
                            class="text-bg/70 hover:text-bg transition-colors duration-300"
                            >Contacto</a
                        >
                    </li>
                </ul>
            </div>

            <div>
                <p class="text-xs uppercase tracking-[0.15em] text-bg/40 mb-4">
                    Contacto
                </p>
                <ul class="space-y-2 text-sm text-bg/70">
                    <li>Santiago, Chile</li>
                    <li>contacto@kumeraweb.com</li>
                </ul>
            </div>
        </div>

        <div
            class="border-t border-bg/15 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-bg/40"
        >
            <p>
                &copy; {new Date().getFullYear()} Sitiora · Kumera Servicios Digitales
                SpA
            </p>
            <p>Cierre comercial manual · Billing Kumera</p>
        </div>
    </div>
</footer>
