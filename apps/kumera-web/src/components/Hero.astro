---
const isKumeraMessagingLive = true;

const companies = [
  {
    name: "Kumera Messaging",
    href: "https://www.kumeramessaging.cl",
    isLive: isKumeraMessagingLive,
  },
  { name: "tractiva", href: "https://www.tractiva.cl" },
  { name: "Sitiora", href: "https://www.sitiora.cl" },
  { name: "TuEjecutiva", href: "https://www.tuejecutiva.cl" },
];
---

<section class="relative overflow-hidden bg-white">
  <div class="pointer-events-none absolute inset-0 flex justify-center">
    <div class="relative w-full max-w-[1120px]">
      <div
        class="absolute right-[-10%] top-[62%] h-[2px] w-[140%] bg-orange-500/10 rotate-[-6deg] animate-line-drift-slow"
      >
      </div>
    </div>
  </div>

  <div class="relative z-10 mx-auto w-full max-w-[1120px] px-6 py-24 md:py-36">
    <div class="max-w-4xl">
      <p
        class="hero-eyebrow text-xs font-medium uppercase tracking-[0.38em] text-black/40"
      >
        KÜMERA WEB SERVICIOS DIGITALES SPA
      </p>

      <h1
        class="pt-6 md:pt-8 hero-title font-['Space_Grotesk'] text-[3.4rem] leading-[1.02] tracking-tight text-black md:text-[5.2rem]"
      >
        <span class="block">Empresa chilena</span>
        <span class="block text-black/40">de desarrollo y</span>
        <span class="block">soluciones digitales.</span>
      </h1>

      <p class="hero-sub py-6 max-w-[60ch] text-lg text-black/70 md:text-xl">
        Diseñamos, desarrollamos y gestionamos productos digitales para empresas
        y proyectos propios. Operamos desde Santiago y Concepción con enfoque en
        ingeniería, diseño y escalabilidad.
      </p>

      <div class="hero-operator py-2">
        <span
          class="inline-flex items-center rounded-full border border-black/10 bg-black/[0.03] px-4 py-2 text-[0.72rem] font-medium uppercase tracking-[0.18em] text-black/55"
          title="Kumera Servicios Digitales SpA opera las marcas y empresas digitales del grupo."
        >
          Empresas operadas por Kumera Servicios Digitales SpA
        </span>
      </div>

      <div class="hero-companies mt-8 max-w-3xl">
        <p class="text-xs font-medium uppercase tracking-[0.3em] text-black/45">
          Empresas y marcas operadas
        </p>
        <div class="mt-4 flex flex-wrap gap-3">
          {
            companies.map((company) => (
              company.href ? (
                <a
                  href={company.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center rounded-full border border-black/10 px-4 py-2 text-sm font-medium text-black/75 transition-all duration-300 hover:-translate-y-[1px] hover:border-black/20 hover:text-black"
                >
                  {company.name}
                </a>
              ) : company.isLive === false ? (
                <span
                  class="inline-flex items-center gap-2 rounded-full border border-amber-200 bg-amber-50 px-4 py-2 text-sm font-medium text-amber-800"
                  title="Kumera Messaging sigue en desarrollo y aun no se publica."
                >
                  <span>{company.name}</span>
                  <span class="rounded-full bg-amber-100 px-2 py-0.5 text-[0.65rem] font-semibold uppercase tracking-[0.14em] text-amber-700">
                    En construcción
                  </span>
                </span>
              ) : (
                <span
                  class="inline-flex items-center rounded-full border border-black/8 bg-black/[0.025] px-4 py-2 text-sm font-medium text-black/45"
                  title="Dominio público no configurado todavía."
                >
                  {company.name}
                </span>
              )
            ))
          }
        </div>
      </div>

      <div class="hero-cta mt-10">
        <a
          href="#contacto"
          class="inline-flex items-center justify-center rounded-full bg-black px-10 py-4 text-xs font-semibold uppercase tracking-[0.24em] text-white transition-all duration-300 hover:translate-y-[-2px] hover:opacity-90"
        >
          Contacto institucional
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-eyebrow,
  .hero-title,
  .hero-sub,
  .hero-cta {
    opacity: 0;
    transform: translateY(14px);
    animation: fadeUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .hero-eyebrow {
    animation-delay: 0.15s;
  }
  .hero-title {
    animation-delay: 0.3s;
  }
  .hero-sub {
    animation-delay: 0.5s;
  }
  .hero-cta {
    animation-delay: 0.65s;
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes lineDrift {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-120px);
    }
  }

  .animate-line-drift-slow {
    animation: lineDrift 32s linear infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow,
    .hero-title,
    .hero-sub,
    .hero-cta,
    .animate-line-drift-slow {
      animation: none !important;
      opacity: 1;
      transform: none;
    }
  }
</style>
