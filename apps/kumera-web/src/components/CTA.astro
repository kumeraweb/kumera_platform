<section id="contacto" class="relative bg-white border-t border-black/5">
  <div class="mx-auto w-full max-w-[1120px] px-6 py-16 md:py-24">
    <div class="space-y-8">
      <p
        class="py-1.5 text-xs font-semibold uppercase tracking-[0.26em] text-black/40"
      >
        Contacto
      </p>
      <h2
        class="font-['Space_Grotesk'] text-4xl leading-[1.1] tracking-tight text-black md:text-5xl"
      >
        Hablemos de tu proyecto
      </h2>
      <p class="py-1.5 max-w-[65ch] text-base text-black/70 md:text-lg">
        Estamos listos para transformar tu visión digital. Contáctanos
        directamente a través de nuestros canales oficiales.
      </p>

      <div class="grid gap-8 pt-8 md:grid-cols-2 lg:grid-cols-3">
        <!-- Email -->
        <a
          href="mailto:contacto@kumeraweb.com"
          class="group flex flex-col justify-between border border-black/10 bg-white p-8 transition-colors hover:border-black/30"
        >
          <div class="mb-6">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-black/60 group-hover:text-black"
              ><rect width="20" height="16" x="2" y="4" rx="2"></rect><path
                d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
            >
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.2em] text-black/50 mb-2">
              Email Corporativo
            </p>
            <p
              class="font-['Space_Grotesk'] text-lg text-black group-hover:underline"
            >
              contacto@kumeraweb.com
            </p>
          </div>
        </a>

        <!-- WhatsApp -->
        <a
          href="https://wa.me/56994186218"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex flex-col justify-between border border-black/10 bg-white p-8 transition-colors hover:border-black/30"
        >
          <div class="mb-6">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-black/60 group-hover:text-black"
              ><path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9L3 21"></path><path
                d="M9 10a.5.5 0 0 0 1 0V9a.5.5 0 0 0-1 0v1a5 5 0 0 0 5 5h1a.5.5 0 0 0 0-1h-1a.5.5 0 0 0 0 1"
              ></path></svg
            >
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.2em] text-black/50 mb-2">
              WhatsApp / Teléfono
            </p>
            <p
              class="font-['Space_Grotesk'] text-lg text-black group-hover:underline"
            >
              +56 9 9418 6218
            </p>
          </div>
        </a>

        <!-- Location -->
        <div
          class="flex flex-col justify-between border border-black/10 bg-black/[0.02] p-8"
        >
          <div class="mb-6">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-black/60"
              ><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"
              ></path><circle cx="12" cy="10" r="3"></circle></svg
            >
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.2em] text-black/50 mb-2">
              Ubicación
            </p>
            <p class="text-sm text-black/80 leading-relaxed">
              Región Metropolitana, Santiago Chile <br />
              Región del Bio Bío, Concepción
            </p>
          </div>
        </div>
      </div>

      <div class="mt-10 border border-black/10 bg-black/[0.02] p-6 md:p-8">
        <h3 class="font-['Space_Grotesk'] text-2xl text-black md:text-3xl">
          Escríbenos
        </h3>
        <p class="mt-2 text-sm text-black/60">
          Completa el formulario y te contactamos a la brevedad.
        </p>

        <form id="kumera-contact-form" class="mt-6 grid gap-4 md:grid-cols-2">
          <label class="block">
            <span class="mb-2 block text-xs uppercase tracking-[0.2em] text-black/50">Nombre</span>
            <input
              type="text"
              name="nombre"
              required
              class="w-full border border-black/15 bg-white px-4 py-3 text-sm text-black outline-none transition-colors focus:border-black/40"
              placeholder="Tu nombre"
            />
          </label>

          <label class="block">
            <span class="mb-2 block text-xs uppercase tracking-[0.2em] text-black/50">Correo</span>
            <input
              type="email"
              name="email"
              required
              class="w-full border border-black/15 bg-white px-4 py-3 text-sm text-black outline-none transition-colors focus:border-black/40"
              placeholder="tu@correo.com"
            />
          </label>

          <label class="block md:col-span-2">
            <span class="mb-2 block text-xs uppercase tracking-[0.2em] text-black/50">Mensaje</span>
            <textarea
              name="mensaje"
              rows="4"
              required
              class="w-full resize-y border border-black/15 bg-white px-4 py-3 text-sm text-black outline-none transition-colors focus:border-black/40"
              placeholder="Cuéntanos brevemente tu necesidad"
            ></textarea>
          </label>

          <div class="md:col-span-2 flex flex-col gap-3 md:flex-row md:items-center">
            <button
              id="kumera-contact-submit"
              type="submit"
              class="inline-flex items-center justify-center bg-black px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-black/85 disabled:cursor-not-allowed disabled:bg-black/50"
            >
              <span id="kumera-contact-submit-text">Enviar mensaje</span>
            </button>
            <p id="kumera-contact-status" class="text-sm text-black/60"></p>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("kumera-contact-form");
  const submitBtn = document.getElementById("kumera-contact-submit");
  const submitText = document.getElementById("kumera-contact-submit-text");
  const status = document.getElementById("kumera-contact-status");

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    submitBtn?.setAttribute("disabled", "true");
    if (submitText) submitText.textContent = "Enviando...";
    if (status) {
      status.textContent = "";
      status.className = "text-sm text-black/60";
    }

    try {
      const response = await fetch("/api/contact", {
        method: "POST",
        body: new FormData(form),
      });

      const raw = await response.text();
      let payload = {};
      try {
        payload = raw ? JSON.parse(raw) : {};
      } catch {
        payload = {};
      }
      if (!response.ok) {
        const backendError =
          (payload && typeof payload === "object" && "error" in payload
            ? payload.error
            : null) || raw || "No se pudo enviar tu mensaje.";
        throw new Error(`[${response.status}] ${backendError}`);
      }

      form.reset();
      if (status) {
        status.textContent = "Gracias por contactarnos. Te responderemos pronto.";
        status.className = "text-sm text-emerald-700";
      }
    } catch (error) {
      if (status) {
        status.textContent =
          error instanceof Error
            ? error.message
            : "No se pudo enviar. Intenta nuevamente.";
        status.className = "text-sm text-rose-700";
      }
    } finally {
      submitBtn?.removeAttribute("disabled");
      if (submitText) submitText.textContent = "Enviar mensaje";
    }
  });
</script>
