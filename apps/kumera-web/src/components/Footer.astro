---
import { contact } from "../data/site";
---

<footer class="border-t border-black/10 bg-white">
  <div
    class="mx-auto w-full max-w-[1120px] px-5 md:px-6 flex flex-col gap-10 md:gap-12 py-16 md:flex-row md:items-start md:justify-between md:py-24"
  >
    <div class="space-y-4 order-1 md:order-none">
      <h3 class="font-['Space_Grotesk'] text-3xl tracking-tight text-black">
        KÜMERA WEB <br /> SERVICIOS DIGITALES SPA
      </h3>
      <p class="max-w-xs text-base text-black/70">
        Constructora de software, aplicaciones y productos digitales.
      </p>
    </div>

    <div class="space-y-3 text-sm text-black/80 order-2 md:order-none">
      <p class="font-medium uppercase tracking-[0.2em] text-black/50">
        Contacto
      </p>
      <p>
        <span class="font-semibold text-black">Ubicación:</span>
        {contact.address}
      </p>
      <p>
        <span class="font-semibold text-black">Teléfono:</span>
        <a class="underline underline-offset-4" href={`tel:${contact.phone}`}
          >{contact.phone}</a
        >
      </p>
      <p>
        <span class="font-semibold text-black">Email:</span>
        <a class="underline underline-offset-4" href={`mailto:${contact.email}`}
          >{contact.email}</a
        >
      </p>
    </div>
  </div>

  <div class="border-t border-black/5">
    <div
      class="mx-auto w-full max-w-[1120px] px-6 flex flex-col gap-2 py-6 text-xs text-black/50 md:flex-row md:items-center md:justify-between"
    >
      <span
        >© {new Date().getFullYear()} KÜMERA WEB SERVICIOS DIGITALES SPA — Todos los
        derechos reservados.</span
      >
      <span>Empresa chilena.</span>
    </div>
  </div>
</footer>
