{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "build/**"],
      "env": [
        "SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_URL",
        "SUPABASE_ANON_KEY",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "NEXT_PUBLIC_APP_URL",
        "APP_CRON_SECRET",
        "CRON_SECRET",
        "ADMIN_BASIC_AUTH_USER",
        "ADMIN_BASIC_AUTH_PASS",
        "TUEJECUTIVA_DB_SCHEMA",
        "TUEJECUTIVA_ENFORCE_BILLING_SUBSCRIPTION",
        "TUEJECUTIVA_SERVICE_SUBJECT_ID",
        "LEADOS_DB_SCHEMA",
        "LEADOS_ENFORCE_BILLING_SUBSCRIPTION",
        "LEADOS_SECRETS_KEY",
        "BACKOFFICE_ADMIN_EMAIL",
        "WHATSAPP_WEBHOOK_VERIFY_TOKEN",
        "INTERNAL_CRON_SECRET",
        "REMINDER_TIMEZONE",
        "REMINDER_ALLOWED_START_HOUR",
        "REMINDER_ALLOWED_END_HOUR",
        "LEAD_REOPEN_COOLDOWN_SECONDS",
        "WEBHOOK_RATE_LIMIT_WINDOW_SECONDS",
        "WEBHOOK_RATE_LIMIT_MAX_MESSAGES",
        "LEAD_MAX_BOT_TURNS",
        "LEAD_MAX_SAME_STEP_EVENTS",
        "OPENAI_API_KEY",
        "RESEND_API_KEY",
        "CONTACT_INBOX_EMAIL",
        "META_API_BASE_URL",
        "NOTIFICATION_FROM_EMAIL",
        "NEXT_PUBLIC_SITE_URL",
        "ALLOWED_ORIGINS",
        "PANEL_PASSWORD",
        "PANEL_LOGIN_RATE_LIMIT_MAX",
        "PANEL_LOGIN_RATE_LIMIT_WINDOW_SEC",
        "PANEL_RESPONDER_RATE_LIMIT_MAX",
        "PANEL_RESPONDER_RATE_LIMIT_WINDOW_SEC",
        "CONTACT_RATE_LIMIT_MAX",
        "CONTACT_RATE_LIMIT_WINDOW_SEC"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^test"]
    }
  }
}
